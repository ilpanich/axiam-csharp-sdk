# Build outputs
bin/
obj/

# Grpc.Tools-generated gRPC/protobuf stubs land under obj/ at build time (D-05) —
# never committed; the compiled stub classes ship inside the published .nupkg instead.

# NuGet packages produced by `dotnet pack`
*.nupkg
*.snupkg

# DocFX output — `docfx metadata` writes api/, `docfx build` writes _site/;
# both are regenerated on every docs-publish run and served from gh-pages.
_site/
api/

# Test + coverage output (coverage.yml)
TestResults/
lcov.info

# IDE / editor
.vs/
*.user
